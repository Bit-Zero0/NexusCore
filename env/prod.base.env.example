NEXUS_ENV=prod
NEXUS_PROCESS_ROLE=embedded
NEXUS_BIND_ADDR=0.0.0.0:8080
NEXUS_CORS_ALLOWED_ORIGINS=https://your-console.example.com

NEXUS_OJ_REPOSITORY=postgres
NEXUS_PG_HOST=postgres.internal
NEXUS_PG_PORT=5432
NEXUS_PG_DATABASE=nexus_code
NEXUS_PG_USERNAME=nexus
NEXUS_PG_PASSWORD=change-me
NEXUS_PG_MAX_CONNECTIONS=20

NEXUS_REDIS_URL=redis://redis.internal:6379/

NEXUS_RUNTIME_WORK_ROOT=/var/lib/nexus/runtime
NEXUS_RUNTIME_NSJAIL_PATH=/usr/bin/nsjail
NEXUS_RUNTIME_NODE_ID=nexus-node-01
NEXUS_RUNTIME_SECCOMP_MODE=kill
NEXUS_RUNTIME_SYSCALL_FLAVOR=auto
NEXUS_RUNTIME_SYSCALL_ARCH=auto
NEXUS_RUNTIME_WORKER_GROUPS="oj-fast=oj_judge:fast;oj-normal=oj_judge:normal;oj-heavy=oj_judge:heavy;oj-special=oj_judge:special"

NEXUS_LOG_FORMAT=json
